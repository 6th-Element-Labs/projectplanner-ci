# /etc/systemd/system/switchboard-auth.service
# ARCH-MS-75 — Auth process-cut unit (side-by-side). Install for soak/testing on
# an unused host port. Do NOT enable production Caddy /api/auth* routing until
# ARCH-MS-76. Keep the monolith Auth mount live (green façade).
#
# Default port 8121 avoids web (:8110), MCP (:8111), and skeleton (:8120).
[Unit]
Description=Switchboard Auth service (:8121, localhost) — SIDE-BY-SIDE (ARCH-MS-75)
After=network-online.target
Wants=network-online.target

[Service]
Slice=projectplanner-interactive.slice
Type=simple
User=projectplanner
Group=projectplanner
WorkingDirectory=/opt/projectplanner
EnvironmentFile=/opt/projectplanner/.env
Environment=PYTHONDONTWRITEBYTECODE=1
Environment=SWITCHBOARD_AUTH_SERVICE_NAME=switchboard-auth
Environment=SWITCHBOARD_AUTH_HOST=127.0.0.1
Environment=SWITCHBOARD_AUTH_PORT=8121
# PYTHONPATH must include repo root + src/ the same way the monolith does.
Environment=PYTHONPATH=/opt/projectplanner:/opt/projectplanner/src
ExecStart=/opt/projectplanner/.venv/bin/uvicorn --factory switchboard.services.auth.app:create_app --host 127.0.0.1 --port 8121
Restart=always
RestartSec=3
TimeoutStartSec=60
TimeoutStopSec=15
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6 AF_NETLINK
ReadWritePaths=/var/lib/projectplanner

[Install]
WantedBy=multi-user.target
