# Example systemd unit for Switchboard Tasks (ARCH-MS-90/91 side-by-side)
#
# ARCH-MS-91: hermetic parity vs in-process is proven in
# tests/test_arch_ms91_tasks_parity.py — install this unit only for local soak.
# Live edge traffic / production dual-strip remains ARCH-MS-92 and still HOLD on
# operator G6 (Phase 3 Path B waived live cut).
#
# Factory: switchboard.services.tasks.app:create_app

[Unit]
Description=Switchboard Tasks service (Mode A — :8122, side-by-side)
After=network.target
PartOf=projectplanner.service

[Service]
Type=simple
User=projectplanner
Group=projectplanner
WorkingDirectory=/opt/projectplanner
Environment=PYTHONUNBUFFERED=1
Environment=SWITCHBOARD_TASKS_SERVICE_NAME=switchboard-tasks
Environment=SWITCHBOARD_TASKS_HOST=127.0.0.1
Environment=SWITCHBOARD_TASKS_PORT=8122
# PYTHONPATH must include repo root + src/ the same way the monolith does.
Environment=PYTHONPATH=/opt/projectplanner:/opt/projectplanner/src
# Live cutover dual-strip (ARCH-MS-92) — leave commented until Caddy points here:
# Environment=PM_TASKS_HTTP_PRIMARY=service
ExecStart=/opt/projectplanner/.venv/bin/uvicorn --factory switchboard.services.tasks.app:create_app --host 127.0.0.1 --port 8122
Restart=on-failure
RestartSec=3
MemoryMax=250M

[Install]
WantedBy=multi-user.target
