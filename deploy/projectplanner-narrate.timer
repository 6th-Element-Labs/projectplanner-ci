# /etc/systemd/system/projectplanner-narrate.timer
# Fires the CEO-voice narrator drain every ~45s (matches PM_NARRATE_INTERVAL
# default in narrate.py). Near-real-time to the operator; the fingerprint +
# activity-cursor guards make idle cycles cost zero LLM calls.
# To enable:
#   sudo cp projectplanner-narrate.{service,timer} /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now projectplanner-narrate.timer
[Unit]
Description=ProjectPlanner CEO-voice narrator drain (every ~45s)

[Timer]
# Monotonic cadence: first run 15s after the timer starts, then 45s after each
# drain completes. OnUnitInactiveSec is intentional: OnUnitActiveSec measures
# from service start, so any drain longer than 45s becomes immediately due and
# loops continuously (BUG-44). Persistent has no effect on monotonic timers.
OnActiveSec=15s
OnUnitInactiveSec=45s
AccuracySec=5s

[Install]
WantedBy=timers.target
