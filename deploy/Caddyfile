# Caddy auto-provisions a Let's Encrypt cert for plan.taikunai.com once DNS
# points at this VM, and reverse-proxies to the app. That's the whole TLS story.
# /mcp* -> the MCP server (Streamable HTTP, :8111); everything else -> the web app (:8110).
plan.taikunai.com {
    handle /mcp* {
        reverse_proxy 127.0.0.1:8111
    }
    handle {
        encode zstd gzip
        reverse_proxy 127.0.0.1:8110
    }
}

# Vanity URL: format.taikunai.com SERVES the self-serve tools page in place (the URL
# stays format.taikunai.com). The root path is internally rewritten to /format.html —
# one page with both boxes (deck rebrand + PDF OCR). The standalone /rebrand.html and
# /ocr.html still work as deep links; everything (CSS, POST /api/*) proxies to :8110.
# Caddy auto-issues the Let's Encrypt cert once the A record resolves to this VM.
format.taikunai.com {
    encode zstd gzip

    @root path /
    rewrite @root /format.html
    reverse_proxy 127.0.0.1:8110
}
