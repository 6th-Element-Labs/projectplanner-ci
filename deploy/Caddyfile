# Caddy auto-provisions a Let's Encrypt cert for plan.taikunai.com once DNS
# points at this VM, and reverse-proxies to the app. That's the whole TLS story.
# /mcp* -> the MCP server (Streamable HTTP, :8111); everything else -> the web app (:8110).
plan.taikunai.com {
    handle /mcp* {
        reverse_proxy 127.0.0.1:8111 {
            transport http {
                dial_timeout 5s
                response_header_timeout 120s
            }
        }
    }
    # Liveness must fail fast — a hung uvicorn must not hold clients for minutes.
    handle /health* {
        reverse_proxy 127.0.0.1:8110 {
            transport http {
                dial_timeout 2s
                response_header_timeout 5s
            }
        }
    }
    handle {
        encode zstd gzip
        # HARDEN-40: long-cache static assets (versioned app.js?v=/*.css?v= and the
        # /vendor/* libs) so browsers don't re-fetch them every load. HTML docs are
        # unmatched here (no extension) and keep the app's Cache-Control: no-cache,
        # so a deploy's new ?v= refs still propagate; /api/* is likewise unmatched.
        @static path *.js *.css *.woff *.woff2 *.ttf *.otf *.png *.jpg *.jpeg *.gif *.svg *.ico /vendor/*
        header @static Cache-Control "public, max-age=604800"
        reverse_proxy 127.0.0.1:8110 {
            transport http {
                dial_timeout 5s
                response_header_timeout 90s
            }
            health_uri /health
            health_interval 5s
            health_timeout 3s
            fail_duration 10s
            # Near-zero-blip deploys: hold a request briefly and retry rather than
            # 503-ing while the upstream restarts (~2-4s). Still fails fast on a real
            # outage (bounded to lb_try_duration), and the 5s active probe re-marks
            # the upstream healthy quickly after it comes back.
            lb_try_duration 5s
            lb_try_interval 250ms
        }
    }
}

# Vanity URL: format.taikunai.com SERVES the self-serve tools page in place (the URL
# stays format.taikunai.com). The root path is internally rewritten to /format.html —
# one page with both boxes (deck rebrand + PDF OCR) — it supersedes the retired standalone
# /rebrand.html and /ocr.html surfaces (CONSOL-7). Everything (CSS, POST /api/*) proxies to :8110.
# Caddy auto-issues the Let's Encrypt cert once the A record resolves to this VM.
format.taikunai.com {
    encode zstd gzip

    @root path /
    rewrite @root /format.html
    reverse_proxy 127.0.0.1:8110 {
        transport http {
            dial_timeout 5s
            response_header_timeout 60s
        }
    }
}
