# Example systemd unit for Switchboard Coord (ARCH-MS-105 side-by-side)
#
# The Go verdict authorizes the localhost process and parity soak only. Live
# Caddy routing remains disabled until the explicit cutover task.

[Unit]
Description=Switchboard Coord service (:8123, side-by-side)
After=network.target
PartOf=projectplanner.service

[Service]
Type=simple
User=projectplanner
Group=projectplanner
WorkingDirectory=/opt/projectplanner
Environment=PYTHONUNBUFFERED=1
Environment=SWITCHBOARD_COORD_SERVICE_NAME=switchboard-coord
Environment=SWITCHBOARD_COORD_HOST=127.0.0.1
Environment=SWITCHBOARD_COORD_PORT=8123
Environment=PYTHONPATH=/opt/projectplanner:/opt/projectplanner/src
ExecStart=/opt/projectplanner/.venv/bin/uvicorn --factory switchboard.services.coord.app:create_app --host 127.0.0.1 --port 8123
Restart=on-failure
RestartSec=3
MemoryMax=250M

[Install]
WantedBy=multi-user.target
