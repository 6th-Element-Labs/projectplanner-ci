# ===== ProjectPlanner environment (copy to .env, fill in, never commit) =====

# OpenAI key — used by the BUNDLED gateway only. The app never sees it.
OPENAI_API_KEY=sk-REPLACE_WITH_OPENAI_KEY

# Gateway master key. The app authenticates to the local gateway with this.
# Set PM_LLM_KEY to the SAME value (systemd EnvironmentFile does not expand vars).
LLM_GATEWAY_MASTER_KEY=sk-projectplanner-CHANGEME
PM_LLM_KEY=sk-projectplanner-CHANGEME

# App -> gateway. These match the code defaults; shown for clarity / overrides.
PM_LLM_BASE_URL=http://127.0.0.1:8095/v1
PM_LLM_CHAT_MODEL=taikun-chat
PM_LLM_EMBED_MODEL=taikun-embed

# Gateway -> tally ledger (UI-12). The LiteLLM success callback posts every
# completion's provider-actual spend here so the Economics panels show real cost.
# Use a DEDICATED least-privilege token, NOT your operator token: the endpoint
# needs only write:ixp, and the gateway proxies every board's LLM calls, so bind
# it to all projects. Mint one with:
#   create_scoped_token(project="*", display_name="litellm-gateway-tally-ingest", scopes="write:ixp")
# Do not reuse PM_MCP_TOKEN here — that grants broad board control and can't be
# revoked without breaking your own access. Unset = callback fires but the ingest
# write is rejected (ledger stays empty).
# PM_TALLY_INGEST_TOKEN=
PM_TALLY_INGEST_URL=http://127.0.0.1:8110/tally/v1/spend/ingest
# Fallback project for calls a caller left untagged (e.g. digest). Tagged calls
# carry their own project in metadata; the token above must be project="*".
PM_TALLY_PROJECT=switchboard

# Storage + content
PM_DB_PATH=/var/lib/projectplanner/plan.db
PM_RAG_CACHE=/var/lib/projectplanner/rag_cache.json
PM_SEED_PATH=/opt/projectplanner/seed_plan.json
PM_DOCS_DIR=/opt/projectplanner/plan-docs
PM_PORT=8110

# MCP server (Phase 1.5). Reads open; writes require this token when set.
# PM_MCP_PORT=8111
# PM_MCP_PUBLIC_HOST=plan.taikunai.com
# PM_MCP_TOKEN=

# Notify (Phase 4). Any unset channel is DRY-RUN (logged, not sent).
# Slack incoming webhook:
# PM_SLACK_WEBHOOK_URL=
# Email via SMTP (works with a Gmail app password or any relay):
# PM_SMTP_HOST=smtp.gmail.com
# PM_SMTP_PORT=587
# PM_SMTP_USER=plan@taikunai.com
# PM_SMTP_PASSWORD=
# PM_SMTP_FROM=plan@taikunai.com
# PM_NOTIFY_EMAIL_TO=you@taikunai.com

# Live Inbox (Phase 5.5) — read plan@taikunai.com via IMAP (app password). No-op until set.
# Enable the timer once configured: sudo systemctl enable --now projectplanner-inbox.timer
# PM_IMAP_HOST=imap.gmail.com
# PM_IMAP_USER=plan@taikunai.com
# PM_IMAP_PASSWORD=
# PM_INBOX_ALLOWLIST=taikunai.com,totalenergies.us   # From must contain one of these (empty = all)
# HARDEN-49: process-local MCP latency/SQLite contention instrumentation.
# PM_MCP_SLOW_CALL_MS=1000
# PM_MCP_METRIC_SAMPLES=2048
# PM_MCP_SLOW_LOG_LIMIT=200
# PM_MCP_TOOL_DEADLINE_S=28
