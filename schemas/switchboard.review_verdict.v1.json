{
  "$defs": {
    "ReviewFinding": {
      "additionalProperties": false,
      "description": "One actionable review finding with durable resolution metadata.",
      "properties": {
        "category": {
          "title": "Category",
          "type": "string"
        },
        "class": {
          "title": "Class",
          "type": "string"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "invariant_violated": {
          "title": "Invariant Violated",
          "type": "string"
        },
        "location": {
          "title": "Location",
          "type": "string"
        },
        "repair_requirement": {
          "title": "Repair Requirement",
          "type": "string"
        },
        "resolved_at": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolved At"
        },
        "resolved_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolved By"
        },
        "resolved_principal_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolved Principal Id"
        },
        "resolved_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolved Reason"
        },
        "resolved_sha": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolved Sha"
        },
        "schema": {
          "default": "switchboard.review_finding.v1",
          "title": "Schema",
          "type": "string"
        },
        "severity": {
          "title": "Severity",
          "type": "string"
        },
        "state": {
          "default": "open",
          "title": "State",
          "type": "string"
        }
      },
      "required": [
        "id",
        "location",
        "category",
        "severity",
        "invariant_violated",
        "repair_requirement",
        "class"
      ],
      "title": "ReviewFinding",
      "type": "object"
    }
  },
  "$id": "switchboard.review_verdict.v1",
  "additionalProperties": false,
  "description": "Persisted review judgment for exactly one task PR head.",
  "properties": {
    "created_at": {
      "title": "Created At",
      "type": "number"
    },
    "finding_count": {
      "default": 0,
      "title": "Finding Count",
      "type": "integer"
    },
    "findings": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ReviewFinding"
      },
      "title": "Findings",
      "type": "array"
    },
    "head_sha": {
      "title": "Head Sha",
      "type": "string"
    },
    "invalidated_by_head_sha": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Invalidated By Head Sha"
    },
    "open_finding_count": {
      "default": 0,
      "title": "Open Finding Count",
      "type": "integer"
    },
    "pr_url": {
      "title": "Pr Url",
      "type": "string"
    },
    "review_mode": {
      "default": "standard",
      "title": "Review Mode",
      "type": "string"
    },
    "reviewer_principal": {
      "title": "Reviewer Principal",
      "type": "string"
    },
    "reviewer_principal_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reviewer Principal Id"
    },
    "schema": {
      "default": "switchboard.review_verdict.v1",
      "title": "Schema",
      "type": "string"
    },
    "source": {
      "default": "review_command",
      "title": "Source",
      "type": "string"
    },
    "status": {
      "title": "Status",
      "type": "string"
    },
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "valid_for_current_head": {
      "default": true,
      "title": "Valid For Current Head",
      "type": "boolean"
    },
    "verdict_id": {
      "title": "Verdict Id",
      "type": "string"
    }
  },
  "required": [
    "verdict_id",
    "task_id",
    "pr_url",
    "head_sha",
    "reviewer_principal",
    "status",
    "created_at"
  ],
  "title": "ReviewVerdict",
  "type": "object"
}
